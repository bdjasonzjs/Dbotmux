{
  "workflowId": "feishu-reply-demo",
  "version": 1,
  "defaults": {
    "retryPolicy": { "maxAttempts": 1, "backoff": "fixed", "baseMs": 1000 },
    "timeoutMs": 60000,
    "maxOutputBytes": 4096
  },
  "nodes": {
    "reply-thread": {
      "type": "hostExecutor",
      "executor": "feishu-reply",
      "input": {
        "larkAppId": "cli_demo_PLACEHOLDER",
        "rootMessageId": "om_demo_PLACEHOLDER",
        "content": "feishu-reply-demo: workflow A3 reply",
        "msgType": "text",
        "replyInThread": false
      }
    }
  }
}
